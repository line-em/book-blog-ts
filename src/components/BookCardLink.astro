---
export interface Props {
  href: string;
  /** Slightly stronger shadow on hover (e.g. genre page). Default: false (home grid). */
  variant?: "default" | "elevated";
}

const { href, variant = "default" } = Astro.props;
const shadowClass =
  variant === "elevated" ? "sm:shadow-sm hover:sm:shadow-md" : "sm:shadow-xs hover:sm:shadow-sm";
---

<a
  href={href}
  class={`link-tilt flex flex-col max-w-60 bg-slate-50/50 border border-white/50 rounded-xl relative p-4 flex-1 items-center hover:text-ctp-rosewater-300 hover:border-ctp-rosewater-200 ${shadowClass}`}
>
  <slot />
</a>
