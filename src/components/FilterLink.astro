---
export interface Props {
  href: string;
  active?: boolean;
}

const { href, active = false } = Astro.props;
const baseClass =
  "link-tilt-stronger flex gap-1 text-base items-center hover:underline rounded-lg px-2 py-1 shadow-xs border bg-slate-50/50 border border-white/50 hover:text-ctp-rosewater-300 hover:border-ctp-rosewater-200";
const activeClass = active ? " pointer-events-none opacity-50" : "";
---

<a href={href} aria-current={active ? "page" : undefined} class={baseClass + activeClass}>
  <slot />
</a>
