---
import { getStars } from "../utils/rating";
import { Image } from "astro:assets";
import { fade } from "astro:transitions";
import { getSortedBooks } from "../utils/getBooks";
import { HashStraightIcon } from "@phosphor-icons/react";
export interface Props {
  year?: number;
}

const { year } = Astro.props;

let allBooks = await getSortedBooks(year);

import { validYears } from "@/content/config";

const pathname = Astro.url.pathname;
const isRoot = pathname === "/" || pathname === "/index.html";
---

<nav class="px-6 mb-2 mt-10 flex justify-center">
  <div class="flex gap-2 flex-wrap items-center justify-center">
    <a
      href="/index.html"
      aria-current={isRoot ? "page" : undefined}
      class={"link-tilt-stronger flex gap-1 text-base items-center hover:underline bg-slate-50 rounded-lg px-2 py-1 shadow border border-transparent hover:text-ctp-rosewater-300 hover:border-ctp-rosewater-200" +
        (isRoot ? " pointer-events-none opacity-50" : "")}
    >
      <HashStraightIcon size={16} color="var(--catppuccin-color-teal-300)" weight="duotone" />
      All Books
    </a>
    {
      validYears.map((currentYear: number) => (
        <a
          href={`/${Number(currentYear)}`}
          aria-current={currentYear === year ? "page" : undefined}
          class={
            "link-tilt-stronger flex gap-1 text-base items-center hover:underline bg-slate-50 rounded-lg px-2 py-1 shadow border border-transparent hover:text-ctp-rosewater-300 hover:border-ctp-rosewater-200" +
            (currentYear === year ? " pointer-events-none opacity-50" : "")
          }
        >
          <HashStraightIcon size={16} color="var(--catppuccin-color-teal-300)" weight="duotone" />
          {currentYear}
        </a>
      ))
    }
  </div>
</nav>
<main class="flex flex-wrap mx-auto gap-8 justify-center p-6 sm:p-8">
  {
    allBooks.map(book => {
      return (
        <a
          transition:animate={fade({ duration: "0.4s" })}
          transition:name={`book-${book?.data.title}`}
          href={`/${book?.id}`}
          class="link-tilt flex flex-col max-w-60 bg-slate-50 sm:shadow-sm rounded-xl relative hover:sm:shadow-md p-4 flex-1 items-center border border-transparent hover:text-ctp-rosewater-300 hover:border-ctp-rosewater-200"
        >
          <div class="overflow-hidden rounded-xl w-[200px] h-[250px] shadow-sm">
            <Image
              src={book && book?.data.image}
              alt={book?.data.title}
              width={200}
              height={250}
              format="webp"
              quality={"high"}
              loading="lazy"
              layout="constrained"
              class="h-auto rounded-xl w-[200px] object-cover"
            />
          </div>
          <aside class="sm:absolute mt-2 sm:mt-0 justify-center sm:-right-3 top-1 z-20 flex gap-1">
            <div class="bg-ctp-teal-100 text-xs text-white px-2 py-1 rounded-md shadow-sm">
              {book?.data.year}
            </div>
            <div class="bg-ctp-rosewater-400 text-xs text-white px-2 py-1 rounded-md shadow-sm">
              {book?.data?.genre[0]}
            </div>
          </aside>
          <h3 class="text-xl my-2 sm:line-clamp-2 items-center whitespace-normal">
            {book?.data.title}
          </h3>
          <span set:html={getStars(book?.data.score)} class="flex mt-auto" />
        </a>
      );
    })
  }
</main>
