---
import { getMostReadGenres } from "../utils/genres";
import { getAverageStars } from "../utils/rating";
import { BookIcon, PlusCircleIcon } from "@phosphor-icons/react";
import GradientText from "../components/GradientText.astro";
import Link from "@/components/Link.astro";
import type { CollectionEntry } from "astro:content";
import type { Genre } from "../utils/genreList";

export interface Props {
  books: CollectionEntry<"books">[];
}

const { books } = Astro.props;

let mostReadGenres: Genre[];
let averageStars;

if (books) {
  mostReadGenres = getMostReadGenres(books);
  averageStars = getAverageStars(books.map(book => book?.data.score));
}
---

<section
  class="absolute top-[-10px] right-[-10px] sm:top-9 sm:right-5 flex items-center px-2 py-2 border border-transparent rounded-xl shadow-sm bg-slate-50 gap-4 w-fit self-center hover:text-ctp-rosewater-400 whitespace-nowrap"
>
  <BookIcon color="var(--catppuccin-color-rosewater-400)" weight="duotone" size="19" />
  <GradientText text={books.length} />
</section>
