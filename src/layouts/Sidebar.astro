---
import type { CollectionEntry } from "astro:content";
import ReadingStats from "./ReadingStats.astro";
import { getSortedBooks } from "../utils/getBooks";
import GradientText from "../components/GradientText.astro";
import { BooksIcon, HouseLineIcon } from "@phosphor-icons/react";

export interface Props {
  currentYear?: number;
  isReview?: boolean;
  bookInfo?: any;
}

const { currentYear, isReview } = Astro.props;

const books: CollectionEntry<"books">[] = currentYear
  ? await getSortedBooks(currentYear)
  : await getSortedBooks();
---

<aside
  class="relative p-6 flex gap-6 bg-ctp-rosewater-50/20 rounded-t-xl mb-12 flex-wrap space-between shadow-md"
>
  <h1 class="text-2xl sm:text-4xl lg:text-5xl mb-4 sm:mb-8 flex text-center gap-2 items-center">
    <BooksIcon size={32} color="var(--catppuccin-color-teal-300)" weight="duotone" />
    <GradientText text={isReview ? "Review" : currentYear ? `${currentYear}` : "Yearly"} />
    Books
  </h1>
  {!isReview && <ReadingStats books={books} mini={true} />}
  {
    isReview && (
      <a
        href="/"
        aria-label="Back to homepage"
        class="absolute top-9 right-5 flex items-center px-2 py-2 border border-transparent rounded-xl shadow-sm bg-slate-50 gap-4 w-fit self-center text-ctp-teal-400 hover:!text-ctp-rosewater-400 whitespace-nowrap"
      >
        <HouseLineIcon size={24} weight="duotone" />
        {/* <span class="hidden sm:inline">Home</span> */}
      </a>
    )
  }
</aside>
