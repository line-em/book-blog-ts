---
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { GENRE_LIST, type Genre } from "../../utils/genreList";
import { compareBookIds } from "../../utils/bookId";
import { getStars } from "../../utils/rating";
import Layout from "../../layouts/Layout.astro";
import Sidebar from "../../layouts/Sidebar.astro";
import BookCardLink from "../../components/BookCardLink.astro";

export async function getStaticPaths() {
  const allBooks: CollectionEntry<"books">[] = await getCollection("books");
  const genreSet = new Set<string>();
  allBooks.forEach(book => {
    (book.data.genre as string[]).forEach(g => genreSet.add(g));
  });
  return Array.from(genreSet)
    .filter(g => GENRE_LIST.includes(g as Genre))
    .map(genre => ({
      params: { genre },
    }));
}

const { genre } = Astro.params;
const allBooks: CollectionEntry<"books">[] = await getCollection("books");

const isValidGenre = genre != null && GENRE_LIST.includes(genre as Genre);
const booksWithGenre = isValidGenre
  ? allBooks
      .filter(book => (book.data.genre as string[]).includes(genre))
      .sort((a, b) => compareBookIds(a.id, b.id))
  : [];
---

<Layout title={`Books in ${genre}`} transition:name={`books`}>
  <Sidebar currentYear={0} />
  <section class="m-6 lg:mx-12">
    <h2 class="text-3xl font-bold">
      Books in <span class="text-ctp-rosewater-500">{genre}</span>
    </h2>
    <main class="flex flex-wrap mx-auto gap-8 justify-center p-6 sm:p-8">
      {
        !isValidGenre ? (
          <p>Invalid genre: {genre}</p>
        ) : booksWithGenre.length === 0 ? (
          <p>No books found for this genre.</p>
        ) : (
          booksWithGenre.map((book) => (
            <BookCardLink href={`/${book.id}`} variant="elevated">
              <div class="flex flex-col flex-1 items-center w-full">
                <div class="overflow-hidden rounded-xl w-[200px] h-[250px] shadow-sm">
                  <Image
                    src={book?.data.image}
                    alt={book?.data.title}
                    width={200}
                    height={250}
                    format="webp"
                    quality={"high"}
                    loading="lazy"
                    layout="constrained"
                    class="h-auto rounded-xl w-[200px] object-cover"
                  />
                </div>
                <aside class="sm:absolute mt-2 sm:mt-0 justify-center sm:-right-3 top-1 z-20 flex gap-1">
                  <div class="bg-ctp-teal-100 text-xs text-white px-2 py-1 rounded-md shadow-sm">
                    {book?.data.year}
                  </div>
                  <div class="bg-ctp-rosewater-400 text-xs text-white px-2 py-1 rounded-md shadow-sm">
                    {book?.data?.genre?.[0]}
                  </div>
                </aside>
                <h3 class="text-xl my-2 sm:line-clamp-2 items-center whitespace-normal">
                  {book?.data.title}
                </h3>
                <span set:html={getStars(book?.data.score)} class="flex mt-auto" />
              </div>
            </BookCardLink>
          ))
        )
      }
    </main>
  </section>
</Layout>
